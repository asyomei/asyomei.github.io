---
import { Image } from "astro:assets";
import avatar from "../avatar.jpg";
---

<div class="flex gap-6">
  <a href="http://www.mashiro.tv/" class="select-none" title="Uryuu~">
    <Image src={avatar} alt="avatar" height={100} class="rounded-full" />
  </a>
  <div class="justify-center flex flex-col gap-3">
    <h1 class="text-2xl">
      <a href="https://mynickname.com/id1805155" class="font-bold">Asyomei</a>
      <p class="fullname">(Vadim Abgalimov)</p>
    </h1>
    <p>
      Beginner developer |
      <a href="https://github.com/asyomei">GitHub</a>
    </p>
  </div>
</div>

<style>
  @media (min-width: 600px) {
    .fullname {
      @apply inline;
    }
  }
</style>
